# OptInPG Production Environment Variables
# Copy to .env and fill in your values

# Backend (all 3 services)
COUNCIL_OUT_DIR=council-out
CORS_ORIGINS=*

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# EAS Attestation (used by dashboard, NOT by agents)
# NEVER put private keys in agent code — only in the dashboard env
# EAS_RPC_URL=https://mainnet.base.org
# EAS_SCHEMA_UID=0x...
